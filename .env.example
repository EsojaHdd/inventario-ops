# InventarioOps — Variables de entorno
# 1. Copiar: cp .env.example .env
# 2. Reemplazar TODOS los valores antes de levantar
# 3. NUNCA subir el archivo .env a Git

# Base de datos — mínimo 16 caracteres
# Generar: openssl rand -base64 16
DB_PASSWORD=CHANGE_ME_MIN_16_CHARS

# JWT Secret — mínimo 64 caracteres
# Generar: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_MIN_64_CHARS_openssl_rand_base64_64
